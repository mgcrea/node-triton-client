{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "rules": {
    "no-explicit-any": "off",
    "no-unused-vars": [
      "error",
      {
        "varsIgnorePattern": "^_",
        "argsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_"
      }
    ]
  },
  "ignorePatterns": ["dist"]
}
