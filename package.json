{
  "name": "@mgcrea/triton-client",
  "version": "0.5.0",
  "description": "TypeScript-ready client for Nvidia Triton inference server",
  "license": "MIT",
  "author": "Olivier Louvignes <olivier@mgcrea.io>",
  "bin": {
    "triton-client": "./dist/bin/cli.cjs"
  },
  "files": [
    "proto",
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch --inspect src/index.ts",
    "cli": "tsx watch --inspect src/bin/cli.ts",
    "build": "tsdown",
    "build:proto": "proto-loader-gen-types --longs=String --enums=String --defaults --oneofs --includeComments --grpcLib=@grpc/grpc-js --outDir=src/types proto/*.proto && oxfmt --write src/types",
    "preview": "node --experimental-specifier-resolution=node --no-warnings dist/index.js",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint src/ test/",
    "check": "tsc --noEmit",
    "spec": "vitest --run --reporter=verbose",
    "coverage": "vitest --run --coverage",
    "watch": "vitest --watch --reporter=verbose",
    "test": "npm run lint && npm run format:check && npm run typecheck && npm run spec",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0"
  },
  "devDependencies": {
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.4",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsdown": "^0.21.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "patchedDependencies": {
      "@grpc/proto-loader@0.8.0": "patches/@grpc__proto-loader@0.8.0.patch"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}