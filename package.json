{
  "name": "@mgcrea/triton-client",
  "version": "0.4.2",
  "description": "TypeScript-ready client for Nvidia Triton inference server",
  "license": "MIT",
  "author": "Olivier Louvignes <olivier@mgcrea.io>",
  "bin": {
    "triton-client": "./dist/bin/cli.cjs"
  },
  "files": [
    "proto",
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch --inspect src/index.ts",
    "cli": "tsx watch --inspect src/bin/cli.ts",
    "build": "tsup --shims --entry src/index.ts --format cjs,esm --sourcemap --dts --clean --entry src/bin/cli.ts",
    "build:proto": "proto-loader-gen-types --longs=String --enums=String --defaults --oneofs --includeComments --grpcLib=@grpc/grpc-js --outDir=src/types proto/*.proto && oxfmt --write src/types",
    "preview": "node --experimental-specifier-resolution=node --no-warnings dist/index.js",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint src/ test/",
    "typecheck": "tsc --noEmit",
    "spec": "vitest --run --reporter=verbose",
    "watch": "vitest --watch --reporter=verbose",
    "test": "npm run lint && npm run format:check && npm run typecheck && npm run spec",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.7",
    "@grpc/proto-loader": "^0.7.13"
  },
  "devDependencies": {
    "@tsconfig/node-lts": "^20.1.3",
    "@tsconfig/strictest": "^2.0.5",
    "@types/node": "^20.12.8",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.2",
    "tsx": "^4.9.0",
    "typescript": "^5.4.5",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^1.5.3"
  },
  "pnpm": {
    "patchedDependencies": {
      "@grpc/proto-loader@0.7.13": "patches/@grpc__proto-loader@0.7.13.patch"
    }
  }
}
